# ============================================================
# private-dns-demo — Environment Variables
# Copy this file to .env and fill in all required values.
# Never commit the actual .env file.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=dnsadmin
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=dnsadmin

# ── Admin API ────────────────────────────────────────────────
# Secret token required in x-admin-token header for all mutating endpoints
ADMIN_API_TOKEN=changeme_admin_api_token

# ── AdGuard Home ─────────────────────────────────────────────
# Web UI password (bcrypt hash generated by bootstrap.sh via htpasswd -B)
# Placeholder — bootstrap.sh will replace this automatically
ADGUARD_ADMIN_USER=admin
ADGUARD_ADMIN_PASSWORD_HASH=$2y$10$placeholder_replace_via_bootstrap

# ── Firewall ─────────────────────────────────────────────────
# Comma-separated list of IPs that are always allowed for SSH (22) and admin UIs
# MUST be set before running bootstrap.sh to prevent lockout
ADMIN_IPS=1.2.3.4,5.6.7.8

# ── Telegram Bot ─────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# Comma-separated Telegram user IDs allowed to use the bot
ADMIN_IDS=123456789,987654321

# URL of the admin-api service (inside Docker network)
ADMIN_API_URL=http://admin-api:8080

# ── Optional TLS (only when DNS_DOMAIN is set) ───────────────
# If set, Caddy will be started (--profile tls) and handle HTTPS
# DNS_DOMAIN=dns.example.com

# Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme_grafana_password

# ── Misc ─────────────────────────────────────────────────────
# Timezone for containers
TZ=UTC
